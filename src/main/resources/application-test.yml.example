server:
  port: 8080

spring:
  data:
    redis:
      host: localhost
      port: 6379

  jwt:
    secret: REPLACE_WITH_TEST_JWT_SECRET

  cloud:
    gateway:
      routes:
        - id: auth-service
          uri: http://localhost:8080
          predicates:
            - Path=/login,/auth/**

        - id: store-service
          uri: http://localhost:8081
          predicates:
            - Path=/stores/**,/menus/**

        - id: notification-service
          uri: http://localhost:8082
          predicates:
            - Path=/notification/**,/alarms/**

gateway:
  secret: REPLACE_WITH_TEST_GATEWAY_SECRET
