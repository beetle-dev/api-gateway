server:
  port: 8000

spring:
  data:
    redis:
      host: localhost
      port: 6379

  jwt:
    secret: REPLACE_WITH_LOCAL_JWT_SECRET

  cloud:
    gateway:
      globalcors:
        cors-configurations:
          '[/**]':
            allowedOrigins:
              - "http://localhost:5173"
            allowedMethods:
              - GET
              - POST
              - PUT
              - DELETE
              - OPTIONS
              - PATCH
            allowedHeaders:
              - "*"
            allowCredentials: true
      routes:
        - id: auth-service
          uri: http://localhost:8080
          predicates:
            - Path=/login,/auth/**

        - id: store-service
          uri: http://localhost:8081
          predicates:
            - Path=/stores/**,/menus/**

        - id: notification-service
          uri: http://localhost:8082
          predicates:
            - Path=/notification/**,/alarms/**

gateway:
  secret: REPLACE_WITH_LOCAL_GATEWAY_SECRET

logging:
  level:
    root: INFO
    org.springframework.web: DEBUG
    org.springframework.cloud.gateway: DEBUG
    reactor.netty.http.client: DEBUG
